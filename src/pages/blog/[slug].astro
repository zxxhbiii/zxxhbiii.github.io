---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

const allPosts = (await getCollection("blog")).sort(
  (a, b) =>
    new Date(b.data.date).getTime() -
    new Date(a.data.date).getTime()
);

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).sort(
    (a, b) =>
      new Date(b.data.date).getTime() -
      new Date(a.data.date).getTime()
  );

  return posts.map((post, index) => ({
    params: {
      slug: post.id,
    },
    props: {
      post,
      previous: posts[index + 1] ?? null,
      next: posts[index - 1] ?? null,
    },
  }));
}

const {
  post,
  previous,
  next,
} = Astro.props;

const { Content } = await render(post);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  canonical={`https://zxxhbiii.github.io/blog/${post.id}/`}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date,
    author: {
      "@type": "Person",
      name: "猫和松鼠",
    },
    publisher: {
      "@type": "Person",
      name: "猫和松鼠",
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `https://zxxhbiii.github.io/blog/${post.id}/`,
    },
  }}
>

<a
href="/blog"
class="text-blue-600 hover:underline"
>
← 返回博客列表
</a>

<h1 class="text-4xl font-bold mt-6 mb-4">

{post.data.title}

</h1>

<div class="text-gray-500 mb-8">

{post.data.date}

&nbsp;·&nbsp;

<div class="flex gap-3 flex-wrap mb-8">     

{
  post.data.tags.map((tag) => (
    <a
      href={`/tags/${tag.toLowerCase()}/`}
      class="px-3 py-1 rounded-full bg-blue-100 text-blue-700 hover:bg-blue-200"
    >
      {tag}
    </a>
  ))
}

</div>

</div>

<article class="prose max-w-none">

<Content />

<hr class="my-12" />

<nav class="flex justify-between gap-8">

  <div>
    {
      previous && (
        <>
          <p class="text-sm text-gray-500">
            ← 上一篇
          </p>

          <a
            href={`/blog/${previous.id}/`}
            class="text-blue-600 hover:underline"
          >
            {previous.data.title}
          </a>
        </>
      )
    }
  </div>

  <div class="text-right">
    {
      next && (
        <>
          <p class="text-sm text-gray-500">
            下一篇 →
          </p>

          <a
            href={`/blog/${next.id}/`}
            class="text-blue-600 hover:underline"
          >
            {next.data.title}
          </a>
        </>
      )
    }
  </div>

</nav>

</article>

</Layout>
