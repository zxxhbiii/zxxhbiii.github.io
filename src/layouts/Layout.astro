---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "记录 AI、SEO、Web 开发学习过程",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{title}</title>

  <meta
    name="description"
    content={description}
  />

  <link
    rel="icon"
    href="/favicon.svg"
  />
</head>

<body class="min-h-screen bg-gray-50 text-gray-900">

<header class="border-b bg-white">

<div class="max-w-5xl mx-auto flex justify-between items-center px-6 py-4">

<a
href="/"
class="text-2xl font-bold"
>
Zxx AI Blog
</a>

<nav class="space-x-6">

<a
href="/"
class="hover:text-blue-600"
>
首页
</a>

<a
href="/blog"
class="hover:text-blue-600"
>
博客
</a>

</nav>

</div>

</header>

<main class="max-w-5xl mx-auto px-6 py-10">

<slot />

</main>

<footer class="border-t mt-16">

<div class="max-w-5xl mx-auto px-6 py-6 text-sm text-gray-500">

© 2026 Zxx AI Blog

</div>

</footer>

</body>

</html>